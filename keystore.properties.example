# Copia questo file come keystore.properties nella ROOT del progetto (accanto a settings.gradle.kts).
# NON committare keystore.properties né il file .jks su Git.
#
# Dopo aver creato il keystore con keytool (vedi GUIDA-PROGETTO.md — Parte 8).

storePassword=LA_TUA_PASSWORD_KEYSTORE
keyPassword=LA_TUA_PASSWORD_CHIAVE
keyAlias=upload
storeFile=percorso/relativo/dalla/root/upload-keystore.jks
